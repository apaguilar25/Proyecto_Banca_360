<+>/* ============================================================\r\n   styles.css — Sistema de diseño Banca 360\r\n   ============================================================ */\r\n\r\n:root {\r\n  --bg-auth-image: url('../assets/fondo-login-claro.png');\r\n  --bg:            #f2f2f7;\r\n  --surface:       #ffffff;\r\n  --surface-2:     #f9f9fb;\r\n  --text:          #1c1c1e;\r\n  --text-secondary:#6e6e73;\r\n  --border:        #e5e5ea;\r\n  --primary:       #0a84ff;\r\n  --primary-dark:  #0066cc;\r\n  --success:       #34c759;\r\n  --error:         #ff3b30;\r\n  --warning:       #ff9500;\r\n  --shadow-sm: 0 1px 2px rgba(0,0,0,.06);\r\n  --shadow-md: 0 6px 20px rgba(0,0,0,.08);\r\n  --radius-sm: 10px;\r\n  --radius-md: 14px;\r\n  --radius-lg: 20px;\r\n}\r\n\r\n[data-theme=\"dark\"] {\r\n  --bg-auth-image: url('../assets/fondo-login-oscuro.png');\r\n  --bg:            #000000;\r\n  --surface:       #1c1c1e;\r\n  --surface-2:     #2c2c2e;\r\n  --text:          #f5f5f7;\r\n  --text-secondary:#a1a1a6;\r\n  --border:        #3a3a3c;\r\n  --primary:       #0a84ff;\r\n  --shadow-sm: 0 1px 2px rgba(0,0,0,.4);\r\n  --shadow-md: 0 6px 20px rgba(0,0,0,.45);\r\n}\r\n\r\n* { \r\n  box-sizing: border-box; \r\n  margin: 0; \r\n  padding: 0; \r\n}\r\n\r\nhtml, body { height: 100%; }\r\nbody {\r\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;\r\n  background: var(--bg);\r\n  color: var(--text);\r\n  -webkit-font-smoothing: antialiased;\r\n  line-height: 1.45;\r\n}\r\na { color: var(--primary); text-decoration: none; }\r\nbutton { font-family: inherit; cursor: pointer; }\r\n\r\n/* ---------- LAYOUT ---------- */\r\n.app-shell { display: flex; flex-direction: column; min-height: 100vh; }\r\n.app-body  { display: flex; flex: 1; flex-direction: row; position: relative; }\r\n.main-content {\r\n  flex: 1; padding: 28px clamp(16px, 4vw, 40px);\r\n  display: flex; flex-direction: column; gap: 20px;\r\n  max-width: 1200px; width: 100%; min-width: 0;\r\n}\r\n\r\n/* ---------- HEADER ---------- */\r\n.header {\r\n  display: flex; align-items: center; justify-content: space-between;\r\n  padding: 14px 24px; background: var(--surface);\r\n  border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 30;\r\n}\r\n.header-left { display: flex; align-items: center; gap: 10px; }\r\n.brand {\r\n  display: inline-flex; align-items: center; gap: 10px;\r\n  font-weight: 700; font-size: 18px; letter-spacing: -0.01em;\r\n  color: var(--text); background: none; border: none; padding: 4px 6px;\r\n  border-radius: 8px; transition: background .15s, transform .1s;\r\n}\r\n.brand:hover { background: var(--surface-2); transform: translateY(-1px); }\r\n.logo-dot {\r\n  width: 32px; height: 32px; border-radius: 8px;\r\n  background: linear-gradient(135deg, var(--primary), #5e5ce6);\r\n  color: #fff; display: flex; align-items: center; justify-content: center;\r\n  font-size: 18px;\r\n}\r\n.header-actions { display: flex; gap: 8px; }\r\n\r\n.icon-btn {\r\n  background: transparent; border: none; color: var(--text);\r\n  width: 36px; height: 36px; border-radius: 50%;\r\n  display: inline-flex; align-items: center; justify-content: center;\r\n  font-size: 20px; transition: background .15s, transform .1s;\r\n}\r\n.icon-btn:hover { background: var(--surface-2); transform: scale(1.05); }\r\n.icon-btn:active { transform: scale(0.95); }\r\n\r\n/* Botón hamburguesa (siempre visible para abrir / cerrar sidebar) */\r\n.hamburger { display: inline-flex; }\r\n\r\n/* ---------- SIDEBAR como DRAWER ---------- */\r\n.sidebar {\r\n  width: 260px;\r\n  background: var(--surface);\r\n  border-right: 1px solid var(--border);\r\n  padding: 20px 12px;\r\n  display: flex; flex-direction: column; gap: 4px;\r\n  position: fixed; top: 64px; bottom: 0; left: 0;\r\n  transform: translateX(-100%);\r\n  transition: transform .25s ease;\r\n  z-index: 25;\r\n  overflow-y: auto;\r\n}\r\n.sidebar.open { transform: translateX(0); box-shadow: var(--shadow-md); }\r\n.sidebar-backdrop {\r\n  position: fixed; inset: 64px 0 0 0; background: rgba(0,0,0,.35);\r\n  z-index: 20; opacity: 0; pointer-events: none; transition: opacity .2s;\r\n}\r\n.sidebar-backdrop.open { opacity: 1; pointer-events: auto; }\r\n\r\n.nav-item {\r\n  display: flex; align-items: center; gap: 12px;\r\n  padding: 11px 14px; border-radius: var(--radius-sm);\r\n  background: transparent; border: none; color: var(--text);\r\n  font-size: 15px; font-weight: 500; text-align: left;\r\n  text-decoration: none;\r\n  transition: background .15s, transform .1s, box-shadow .15s;\r\n}\r\n.nav-item:hover {\r\n  background: var(--surface-2);\r\n  transform: translateX(2px);\r\n  box-shadow: var(--shadow-sm);\r\n}\r\n.nav-item.active {\r\n  background: color-mix(in srgb, var(--primary) 14%, transparent);\r\n  color: var(--primary);\r\n}\r\n.nav-item i { font-size: 20px; }\r\n\r\n/* Botón \"Volver al dashboard\" en submenús */\r\n.back-link {\r\n  display: inline-flex; align-items: center; gap: 6px;\r\n  color: var(--primary); font-weight: 500; font-size: 14px;\r\n  padding: 6px 10px; border-radius: 8px;\r\n  transition: background .15s, transform .1s;\r\n  width: fit-content;\r\n}\r\n.back-link:hover { background: var(--surface-2); transform: translateX(-3px); }\r\n.back-link i { font-size: 18px; }\r\n\r\n/* ---------- TIPOGRAFÍA ---------- */\r\n.page-title { font-size: 28px; font-weight: 700; letter-spacing: -0.02em; }\r\n.section-title { font-size: 17px; font-weight: 600; margin-bottom: 8px; }\r\n.text-muted { color: var(--text-secondary); }\r\n\r\n/* ---------- TARJETAS ---------- */\r\n.card {\r\n  background: var(--surface);\r\n  border-radius: var(--radius-lg);\r\n  padding: 20px;\r\n  box-shadow: var(--shadow-sm);\r\n  border: 1px solid var(--border);\r\n}\r\n.card + .card { margin-top: 16px; }\r\n\r\n/* Tarjeta de saldo */\r\n.balance-card {\r\n  background: linear-gradient(135deg, #0a84ff, #5e5ce6);\r\n  color: #fff;\r\n  border-radius: var(--radius-lg);\r\n  padding: 24px;\r\n  display: flex; flex-direction: column; gap: 10px;\r\n  box-shadow: var(--shadow-md);\r\n  min-width: 0;\r\n}\r\n.balance-card .label { font-size: 13px; opacity: .85; }\r\n.balance-card .amount-row {\r\n  display: flex; align-items: center; justify-content: space-between;\r\n  gap: 12px; min-width: 0;\r\n}\r\n.balance-card .amount {\r\n  font-size: clamp(20px, 6vw, 34px);\r\n  font-weight: 700; letter-spacing: -0.02em;\r\n  overflow-wrap: anywhere; word-break: break-all;\r\n  min-width: 0; flex: 1;\r\n}\r\n.balance-card .acct { font-size: 13px; opacity: .85; }\r\n\r\n/* Toggle de saldo: ancho fijo para que no se mueva */\r\n.toggle-balance-btn {\r\n  width: 36px; height: 36px; min-width: 36px; flex-shrink: 0;\r\n  color: inherit;\r\n}\r\n\r\n/* ---------- FORMULARIOS ---------- */\r\n.form-grid {\r\n  display: flex; flex-wrap: wrap; gap: 14px;\r\n}\r\n.form-grid .form-group { flex: 1 1 220px; margin-bottom: 0; }\r\n.form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }\r\n.form-label { font-size: 13px; font-weight: 500; color: var(--text-secondary); }\r\n.form-input, .form-select {\r\n  padding: 12px 14px;\r\n  border: 1px solid var(--border);\r\n  border-radius: var(--radius-sm);\r\n  background: var(--surface-2);\r\n  color: var(--text);\r\n  font-size: 15px; font-family: inherit;\r\n  outline: none; transition: border-color .15s, box-shadow .15s;\r\n  width: 100%;\r\n}\r\n.form-input:focus, .form-select:focus {\r\n  border-color: var(--primary);\r\n  box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 20%, transparent);\r\n}\r\n\r\n/* Input compuesto: select prefijo + input texto */\r\n.input-compound {\r\n  display: flex; gap: 0;\r\n  border: 1px solid var(--border);\r\n  border-radius: var(--radius-sm);\r\n  background: var(--surface-2);\r\n  overflow: hidden;\r\n  transition: border-color .15s, box-shadow .15s;\r\n}\r\n.input-compound:focus-within {\r\n  border-color: var(--primary);\r\n  box-shadow: 0 0 0 3px color-mix(in srgb, var(--primary) 20%, transparent);\r\n}\r\n.input-compound select,\r\n.input-compound input {\r\n  border: none; background: transparent; padding: 12px 12px;\r\n  font-size: 15px; color: var(--text); outline: none; font-family: inherit;\r\n}\r\n.input-compound select {\r\n  border-right: 1px solid var(--border);\r\n  font-weight: 600;\r\n  background: var(--surface);\r\n  padding-right: 28px;\r\n  flex-shrink: 0;\r\n}\r\n.input-compound input { flex: 1; min-width: 0; }\r\n\r\n/* Wrapper para password con botón mostrar/ocultar */\r\n.password-wrap { position: relative; display: flex; align-items: center; }\r\n.password-wrap .form-input { padding-right: 44px; }\r\n.password-toggle {\r\n  position: absolute; right: 6px; top: 50%; transform: translateY(-50%);\r\n  background: transparent; border: none; color: var(--text-secondary);\r\n  width: 32px; height: 32px; border-radius: 50%;\r\n  display: inline-flex; align-items: center; justify-content: center;\r\n  font-size: 18px; transition: background .15s, color .15s;\r\n}\r\n.password-toggle:hover { background: var(--surface-2); color: var(--primary); }\r\n\r\n.form-error {\r\n  color: var(--error); font-size: 13px; margin-top: 4px;\r\n  background: color-mix(in srgb, var(--error) 10%, transparent);\r\n  border-left: 3px solid var(--error);\r\n  padding: 8px 10px; border-radius: 6px;\r\n  animation: error-pop .35s ease-out;\r\n}\r\n@keyframes error-pop {\r\n  from { opacity: 0; transform: translateY(-4px) scale(.98); }\r\n  to   { opacity: 1; transform: translateY(0) scale(1); }\r\n}\r\n.form-success {\r\n  color: var(--success); font-size: 13px; margin-top: 4px;\r\n  background: color-mix(in srgb, var(--success) 10%, transparent);\r\n  border-left: 3px solid var(--success);\r\n  padding: 8px 10px; border-radius: 6px;\r\n  animation: error-pop .35s ease-out;\r\n}\r\n.form-footer { text-align: center; margin-top: 18px; font-size: 14px; color: var(--text-secondary); }\r\n\r\n/* ---------- BOTONES ---------- */\r\n.btn-primary, .btn-secondary, .btn-destructive {\r\n  display: inline-flex; align-items: center; justify-content: center; gap: 8px;\r\n  padding: 12px 18px; border-radius: var(--radius-sm);\r\n  font-size: 15px; font-weight: 600;\r\n  border: none; transition: transform .12s, box-shadow .15s, opacity .15s, filter .15s;\r\n}\r\n.btn-primary { background: var(--primary); color: #fff; }\r\n.btn-primary:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); filter: brightness(1.05); }\r\n.btn-secondary { background: var(--surface-2); color: var(--text); border: 1px solid var(--border); }\r\n.btn-secondary:hover { transform: translateY(-1px); box-shadow: var(--shadow-sm); background: var(--surface); }\r\n.btn-destructive { background: var(--error); color: #fff; }\r\n.btn-destructive:hover { transform: translateY(-1px); box-shadow: var(--shadow-md); filter: brightness(1.05); }\r\n.btn-primary:active, .btn-secondary:active, .btn-destructive:active { transform: scale(.97); }\r\nbutton:disabled { opacity: .6; cursor: not-allowed; transform: none !important; }\r\n\r\n.ios-spinner {\r\n  width: 18px; height: 18px;\r\n  border: 2px solid rgba(255,255,255,.35);\r\n  border-top-color: #fff;\r\n  border-radius: 50%;\r\n  animation: spin .8s linear infinite;\r\n}\r\n@keyframes spin { to { transform: rotate(360deg); } }\r\n\r\n/* ---------- LISTAS iOS ---------- */\r\n.ios-list {\r\n  background: var(--surface);\r\n  border-radius: var(--radius-md);\r\n  border: 1px solid var(--border);\r\n  overflow: hidden;\r\n  display: flex; flex-direction: column;\r\n}\r\n.ios-list-header {\r\n  padding: 12px 16px; font-size: 13px; font-weight: 600;\r\n  text-transform: uppercase; letter-spacing: .04em;\r\n  color: var(--text-secondary); background: var(--surface-2);\r\n  border-bottom: 1px solid var(--border);\r\n  display: flex; align-items: center; justify-content: space-between; gap: 10px;\r\n}\r\n.ios-list-header .icon-btn { width: 28px; height: 28px; font-size: 16px; }\r\n.ios-list-item {\r\n  display: flex; align-items: center; gap: 14px;\r\n  padding: 14px 16px;\r\n  background: transparent; border: none; border-bottom: 1px solid var(--border);\r\n  color: var(--text); text-align: left; width: 100%;\r\n  transition: background .15s;\r\n}\r\n.ios-list-item:last-child { border-bottom: none; }\r\n.ios-list-item:hover { background: var(--surface-2); }\r\n\r\n.icon-circle {\r\n  width: 38px; height: 38px; border-radius: 50%;\r\n  display: inline-flex; align-items: center; justify-content: center;\r\n  font-size: 18px; flex-shrink: 0;\r\n}\r\n.icon-circle.in  { background: color-mix(in srgb, var(--success) 18%, transparent); color: var(--success); }\r\n.icon-circle.out { background: color-mix(in srgb, var(--error) 18%, transparent);   color: var(--error); }\r\n\r\n.txn-info { flex: 1; display: flex; flex-direction: column; min-width: 0; }\r\n.txn-desc { font-size: 15px; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\r\n.txn-date { font-size: 12px; color: var(--text-secondary); }\r\n.txn-amount { font-size: 15px; font-weight: 600; white-space: nowrap; }\r\n.txn-amount.in  { color: var(--success); }\r\n.txn-amount.out { color: var(--error); }\r\n\r\n/* ---------- FILTROS HISTORIAL ---------- */\r\n.history-filters {\r\n  display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;\r\n}\r\n.history-filters .filter-block { display: flex; flex-direction: column; gap: 4px; }\r\n.history-filters label { font-size: 12px; color: var(--text-secondary); font-weight: 500; }\r\n\r\n.segmented {\r\n  display: flex; background: var(--surface-2);\r\n  border-radius: var(--radius-sm); padding: 4px; gap: 4px;\r\n}\r\n.segmented button {\r\n  flex: 1; padding: 8px 14px; border-radius: 8px;\r\n  background: transparent; border: none; color: var(--text);\r\n  font-size: 14px; font-weight: 500; transition: background .15s, transform .1s;\r\n  white-space: nowrap;\r\n}\r\n.segmented button:hover { transform: translateY(-1px); }\r\n.segmented button.active { background: var(--surface); box-shadow: var(--shadow-sm); }\r\n\r\n\r\n/* ---------- AUTH ---------- */\r\n\r\n.auth-screen {\r\n  min-height: 100vh;\r\n  display: flex; \r\n  align-items: center; \r\n  justify-content: center;\r\n  padding: 20px; \r\n  position: relative;\r\n  \r\n  /* Configuración del fondo */\r\n  background-position: center;\r\n  background-repeat: no-repeat;\r\n  background-size: cover;\r\n  background-attachment: fixed;\r\n\r\n\r\n  /* Variable para la imagen de fondo en pantallas de autenticación */\r\n  background-image: \r\n    var(--bg-auth-image);\r\n}\r\n\r\n.auth-tools {\r\n  position: absolute; top: 20px; right: 20px; display: flex; gap: 8px;\r\n}\r\n.auth-card {\r\n  background: var(--surface);\r\n  border-radius: var(--radius-lg);\r\n  padding: 32px;\r\n  width: 100%; max-width: 460px;\r\n  box-shadow: var(--shadow-md);\r\n  border: 1px solid var(--border);\r\n  display: flex; flex-direction: column;\r\n}\r\n.auth-card .brand-hero {\r\n  display: flex; flex-direction: column; align-items: center; gap: 10px;\r\n  margin-bottom: 18px;\r\n}\r\n.auth-card .brand-hero .logo-dot { width: 52px; height: 52px; font-size: 28px; border-radius: 14px; }\r\n.auth-card h1 { font-size: 24px; font-weight: 700; letter-spacing: -0.02em; text-align: center; }\r\n.auth-card .subtitle { color: var(--text-secondary); text-align: center; margin: 6px 0 22px; font-size: 14px; }\r\n\r\n/* Tabs (Correo / Cédula en login) */\r\n.tabs {\r\n  display: flex; gap: 4px; padding: 4px;\r\n  background: var(--surface-2); border-radius: var(--radius-sm);\r\n  margin-bottom: 14px;\r\n}\r\n.tabs button {\r\n  flex: 1; padding: 8px 12px; border-radius: 8px;\r\n  background: transparent; border: none; color: var(--text);\r\n  font-size: 14px; font-weight: 500; transition: background .15s;\r\n}\r\n.tabs button.active { background: var(--surface); box-shadow: var(--shadow-sm); color: var(--primary); }\r\n\r\n/* ---------- PERFIL ---------- */\r\n.profile-header { display: flex; align-items: center; gap: 16px; margin-bottom: 18px; }\r\n.avatar {\r\n  width: 64px; height: 64px; border-radius: 50%;\r\n  background: linear-gradient(135deg, var(--primary), #5e5ce6);\r\n  color: #fff; display: flex; align-items: center; justify-content: center;\r\n  font-size: 26px; font-weight: 700;\r\n}\r\n.profile-header h2 { font-size: 18px; font-weight: 600; }\r\n.profile-header p { color: var(--text-secondary); font-size: 14px; word-break: break-all; }\r\n\r\n.settings-list { display: flex; flex-direction: column; }\r\n.settings-row {\r\n  display: flex; align-items: center; justify-content: space-between;\r\n  padding: 14px 0;\r\n  border-bottom: 1px solid var(--border);\r\n  background: transparent; gap: 10px;\r\n}\r\n.settings-row:last-child { border-bottom: none; }\r\n.settings-row .left  { display: flex; align-items: center; gap: 10px; color: var(--text); }\r\n.settings-row .right { color: var(--text-secondary); font-size: 14px; display: flex; align-items: center; gap: 6px; word-break: break-all; text-align: right; }\r\n.settings-row i { font-size: 18px; }\r\n\r\n/* ---------- MODAL ---------- */\r\n.modal-backdrop {\r\n  position: fixed; inset: 0; background: rgba(0,0,0,.4);\r\n  display: flex; align-items: center; justify-content: center;\r\n  z-index: 100; padding: 16px;\r\n  animation: fade-in .2s ease-out;\r\n}\r\n@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }\r\n.modal {\r\n  background: var(--surface);\r\n  border-radius: var(--radius-lg);\r\n  width: 100%; max-width: 440px;\r\n  display: flex; flex-direction: column;\r\n  box-shadow: var(--shadow-md);\r\n  animation: modal-pop .25s cubic-bezier(.2,.9,.3,1.1);\r\n  max-height: 90vh;\r\n}\r\n@keyframes modal-pop {\r\n  from { opacity: 0; transform: translateY(10px) scale(.97); }\r\n  to   { opacity: 1; transform: translateY(0) scale(1); }\r\n}\r\n.modal-header {\r\n  display: flex; align-items: center; justify-content: space-between;\r\n  padding: 16px 20px; border-bottom: 1px solid var(--border);\r\n}\r\n.modal-header h2 { font-size: 17px; font-weight: 600; }\r\n.modal-body { padding: 18px 20px; display: flex; flex-direction: column; gap: 10px; overflow-y: auto; }\r\n.modal-row {\r\n  display: flex; justify-content: space-between; gap: 12px;\r\n  padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 14px;\r\n}\r\n.modal-row:last-child { border-bottom: none; }\r\n.modal-row .key { color: var(--text-secondary); }\r\n.modal-row .val { font-weight: 500; text-align: right; word-break: break-all; }\r\n.modal-footer {\r\n  display: flex; gap: 10px; padding: 14px 20px;\r\n  border-top: 1px solid var(--border); justify-content: flex-end;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n/* ---------- SESIÓN FINALIZADA ---------- */\r\n.session-end {\r\n  min-height: 100vh;\r\n  display: flex; flex-direction: column; align-items: center; justify-content: center;\r\n  text-align: center; padding: 24px; gap: 14px; position: relative;\r\n  background:\r\n    radial-gradient(circle at 20% 10%, color-mix(in srgb, var(--primary) 18%, transparent), transparent 50%),\r\n    radial-gradient(circle at 80% 90%, color-mix(in srgb, #5e5ce6 22%, transparent), transparent 55%),\r\n    var(--bg);\r\n}\r\n.session-end .session-logo {\r\n  width: 84px; height: 84px; border-radius: 22px;\r\n  background: linear-gradient(135deg, var(--primary), #5e5ce6);\r\n  color: #fff; display: flex; align-items: center; justify-content: center;\r\n  font-size: 42px; margin-bottom: 8px;\r\n  box-shadow: var(--shadow-md);\r\n  animation: modal-pop .4s ease-out;\r\n}\r\n.session-end h1 { font-size: 26px; font-weight: 700; }\r\n.session-end p { color: var(--text-secondary); max-width: 380px; }\r\n.session-end .session-actions {\r\n  display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; justify-content: center;\r\n}\r\n\r\n/* ---------- UTILIDADES ---------- */\r\n.flex-row { display: flex; gap: 12px; flex-wrap: wrap; }\r\n.mt-16 { margin-top: 16px; } .mt-24 { margin-top: 24px; }\r\n\r\n/* ---------- RESPONSIVE ---------- */\r\n@media (max-width: 800px) {\r\n  .header { padding: 12px 14px; }\r\n  .main-content { padding: 18px; }\r\n  .balance-card { padding: 20px; }\r\n  .form-grid .form-group { flex: 1 1 100%; }\r\n  .session-end .shield { width: 70px; height: 70px; font-size: 34px; }\r\n}\r\n
